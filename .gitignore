# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets — do NOT commit
# Gemini API key lives here; copy environment.example.dart -> environment.dart locally.
lib/environments/environment.dart

# Firebase config (defense in depth — these contain project + app identifiers
# and per-platform API keys generated by `flutterfire configure`).
# Re-generate locally with: flutterfire configure --project=workshop-gdg-rec
lib/firebase_options.dart
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
